# Root of the config tree — stops Lombok searching parent directories.
config.stopBubbling = true

# Mark every Lombok-generated member with @lombok.Generated so static analysers
# (CodeQL, SpotBugs, JaCoCo) skip generated code — e.g. java/missing-override-annotation
# on @Data getters that implement an interface, and the Lombok RCN_REDUNDANT_NULLCHECK reports.
lombok.addLombokGeneratedAnnotation = true
