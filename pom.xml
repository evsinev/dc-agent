    <build>
        <plugins>

            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <configuration>
                    <!-- Coverage targets the business/util/parser/mapper/service logic. Excluded:
                         app bootstrap/wiring, GraalVM native-image codegen, exec wrappers (daemontools),
                         HTTP clients / remote plane, and the HTTP boundary (servlets + error filters) —
                         these need a running server / network / OS binaries and are not unit-testable. -->
                    <excludes>
                        <!-- bootstrap / wiring -->
                        <exclude>com/payneteasy/dcagent/DcAgentApplication.class</exclude>
                        <exclude>com/payneteasy/dcagent/operator/DcAgentOperatorApplication.class</exclude>
                        <exclude>com/payneteasy/dcagent/operator/DcOperatorFactory.class</exclude>
                        <!-- GraalVM native-image build-time codegen -->
                        <exclude>com/payneteasy/dcagent/graalvm/**</exclude>
                        <!-- exec wrappers (spawn svc/svstat, wait on URLs) -->
                        <exclude>com/payneteasy/dcagent/core/modules/jar/DaemontoolsServiceImpl.class</exclude>
                        <exclude>com/payneteasy/dcagent/core/modules/jar/WaitUrlCommand.class</exclude>
                        <exclude>com/payneteasy/dcagent/core/modules/jar/ServiceLoopDetector.class</exclude>
                        <!-- HTTP clients / remote control-plane plumbing -->
                        <exclude>com/payneteasy/dcagent/core/remote/**</exclude>
                        <exclude>com/payneteasy/dcagent/core/job/send/impl/SendJobServiceImpl.class</exclude>
                        <exclude>com/payneteasy/dcagent/controlplane/DcAgentControlPlaneRemoteServiceImpl.class</exclude>
                        <!-- Raw URL download shell; its path/URL resolution lives in (tested) ResolverContext -->
                        <exclude>com/payneteasy/dcagent/core/modules/docker/resolver/FileFetchUrlResolver.class</exclude>
                        <!-- HTTP boundary: servlets and error filters -->
                        <exclude>com/payneteasy/dcagent/servlets/**</exclude>
                        <exclude>com/payneteasy/dcagent/jetty/ErrorFilter.class</exclude>
                        <exclude>com/payneteasy/dcagent/jetty/FilterErrors.class</exclude>
                        <exclude>com/payneteasy/dcagent/jetty/JettyContextRepository.class</exclude>
                        <exclude>com/payneteasy/dcagent/jetty/ExceptionHandlerImpl.class</exclude>
                        <exclude>com/payneteasy/dcagent/controlplane/filter/**</exclude>
                        <exclude>com/payneteasy/dcagent/operator/servlet/**</exclude>
                        <exclude>com/payneteasy/dcagent/operator/filter/**</exclude>
                        <!-- system/metrics collection via OS -->
                        <exclude>com/payneteasy/dcagent/metrics/**</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.15.0</version>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <showWarnings>true</showWarnings>
                    <showDeprecation>true</showDeprecation>
                </configuration>
            </plugin>

            <plugin>
                <groupId>com.github.spotbugs</groupId>
                <artifactId>spotbugs-maven-plugin</artifactId>
                <version>4.10.3.0</version>
                <configuration>
                    <effort>Max</effort>
                    <threshold>Medium</threshold>
                    <sarifOutput>true</sarifOutput>
                    <!-- Root-level filter; absolute path so it resolves the same for every module -->
                    <excludeFilterFile>${maven.multiModuleProjectDirectory}/spotbugs-exclude.xml</excludeFilterFile>
                    <!-- FindSecBugs adds ~130 security detectors on top of SpotBugs -->
                    <plugins>
                        <plugin>
                            <groupId>com.h3xstream.findsecbugs</groupId>
                            <artifactId>findsecbugs-plugin</artifactId>
                            <version>1.14.0</version>
                        </plugin>
                    </plugins>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>3.6.0</version>
                <!--
                  Intentionally NOT bound to any build phase: Checkstyle does NOT run during
                  `./mvnw package` / `./mvnw verify`. Run it on demand instead:
                    tools/checkstyle-report.sh   -> builds target/checkstyle-report.html
                    ./mvnw checkstyle:check      -> console + per-module target/checkstyle-result.xml
                  The configuration below is inherited by that command-line invocation. To make
                  Checkstyle enforcing again, wrap it in an <executions> block binding the `check`
                  goal to the `validate` phase and set failOnViolation/failsOnError to true.
                -->
                <configuration>
                    <configLocation>checkstyle.xml</configLocation>
                    <suppressionsLocation>checkstyle-suppressions.xml</suppressionsLocation>
                    <encoding>UTF-8</encoding>
                    <consoleOutput>true</consoleOutput>
                    <failsOnError>false</failsOnError>
                    <failOnViolation>false</failOnViolation>
                </configuration>
            </plugin>

        </plugins>
    </build>

    <!--
      Spotless is available on demand only (like Checkstyle above) — it is NOT bound to any build
      phase and is guarded behind a profile per formatter, so a normal `./mvnw package` never runs it.
      Two mutually-exclusive formatter variants are provided so their output can be compared:

        ./mvnw -Pspotless-palantir spotless:check   (or spotless:apply)
        ./mvnw -Pspotless-google   spotless:check   (or spotless:apply)

      Report scripts wrapping these live in tools/:
        tools/spotless-report.sh          -> target/spotless-report-{palantir,google}.html

      NOTE: palantir-java-format and google-java-format reach into JDK-internal com.sun.tools.javac
      packages, so on JDK 16+ Maven must be launched with add-exports/add-opens for jdk.compiler.
      The report scripts set these via MAVEN_OPTS; for a manual run export the same flags first (see
      tools/spotless-report.sh). They are intentionally kept out of .mvn/jvm.config so ordinary builds
      are unaffected.
    -->
    <profiles>
        <profile>
            <id>spotless-palantir</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>com.diffplug.spotless</groupId>
                        <artifactId>spotless-maven-plugin</artifactId>
                        <version>${spotless.version}</version>
                        <configuration>
                            <java>
                                <includes>
                                    <include>src/main/java/**/*.java</include>
                                </includes>
                                <palantirJavaFormat>
                                    <version>${palantir.java.format.version}</version>
                                </palantirJavaFormat>
                            </java>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <profile>
            <id>spotless-google</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>com.diffplug.spotless</groupId>
                        <artifactId>spotless-maven-plugin</artifactId>
                        <version>${spotless.version}</version>
                        <configuration>
                            <java>
                                <includes>
                                    <include>src/main/java/**/*.java</include>
                                </includes>
                                <googleJavaFormat>
                                    <version>${google.java.format.version}</version>
                                </googleJavaFormat>
                            </java>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!--
          Error Prone (Google) is a javac compiler plugin, so it only runs during compilation and only
          under this profile. A normal build never enables it. On JDK 16+ the forked compiler JVM needs
          jdk.compiler internals opened (the -J add-exports/add-opens below); error_prone_core plus Lombok
          are BOTH listed on annotationProcessorPaths because declaring that list disables classpath
          processor scanning (omitting Lombok would break its code generation). Errors are downgraded to
          warnings (-XepAllErrorsAsWarnings) so a full compile completes and every finding is reported.

            ./mvnw -Perrorprone -Dfrontend.skip=true clean compile   (see tools/errorprone-report.sh)
        -->
        <profile>
            <id>errorprone</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-compiler-plugin</artifactId>
                        <configuration>
                            <fork>true</fork>
                            <showWarnings>true</showWarnings>
                            <failOnWarning>true</failOnWarning>
                            <compilerArgs>
                                <arg>-XDcompilePolicy=simple</arg>
                                <arg>--should-stop=ifError=FLOW</arg>
                                <arg>-XDaddTypeAnnotationsToSymbol=true</arg>
                                <arg>-Xplugin:ErrorProne -XepAllErrorsAsWarnings -Xep:NullAway:ERROR -XepOpt:NullAway:OnlyNullMarked=true -XepOpt:NullAway:JSpecifyMode=true</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.processing=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED</arg>
                                <arg>-J--add-exports=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED</arg>
                                <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED</arg>
                                <arg>-J--add-opens=jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED</arg>
                            </compilerArgs>
                            <annotationProcessorPaths>
                                <!-- Lombok ПЕРВЫМ: генерирует код до того, как его увидят
                                     Error Prone / NullAway, иначе ложные срабатывания -->
                                <path>
                                    <groupId>org.projectlombok</groupId>
                                    <artifactId>lombok</artifactId>
                                    <version>${lombok.version}</version>
                                </path>
                                <path>
                                    <groupId>com.google.errorprone</groupId>
                                    <artifactId>error_prone_core</artifactId>
                                    <version>${errorprone.version}</version>
                                </path>
                                <path>
                                    <groupId>com.uber.nullaway</groupId>
                                    <artifactId>nullaway</artifactId>
                                    <version>${nullaway.version}</version>
                                </path>
                            </annotationProcessorPaths>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>    </profiles>

</project>
